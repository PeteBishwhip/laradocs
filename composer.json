{
    "name": "artmanclassic/laradocs-php7.3",
    "description": "LaraDocs backport for PHP 7.3 and Laravel 8: Markdown documentation rendered as a polished Laravel site.",
    "keywords": [
        "laravel",
        "documentation",
        "docs",
        "markdown",
        "commonmark"
    ],
    "homepage": "https://github.com/artmanclassic/laradocs-php7.3",
    "license": "MIT",
    "authors": [
        {
            "name": "Pete Bishop",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^7.3 || ^8.0",
        "devizzent/cebe-php-openapi": "^1.0",
        "illuminate/contracts": "^8.0",
        "illuminate/support": "^8.0",
        "league/commonmark": "^1.6",
        "symfony/polyfill-php80": "^1.22",
        "symfony/polyfill-php81": "^1.23",
        "symfony/yaml": "^5.1"
    },
    "require-dev": {
        "guzzlehttp/guzzle": "^7.2",
        "laravel/scout": "^8.6",
        "orchestra/testbench": "^6.22",
        "pestphp/pest": "^1.21",
        "pestphp/pest-plugin-laravel": "^1.1",
        "phpstan/phpstan": "^1.10"
    },
    "suggest": {
        "laravel/scout": "Power full-text docs search with a Laravel 8-compatible Scout 8 installation (falls back to the built-in JSON index).",
        "nyholm/psr7": "When using Meilisearch via Scout, install a PSR-17 factory (nyholm/psr7, guzzlehttp/psr7 ^2, or symfony/http-client) so the Meilisearch SDK can build HTTP requests.",
        "simonhamp/the-og": "Optional Open Graph image generation; no PHP 7.3-compatible release is currently available.",
        "laravel/mcp": "Optional MCP support is disabled on PHP 7.3 because laravel/mcp requires a newer PHP and Laravel release."
    },
    "autoload": {
        "psr-4": {
            "Laradocs\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Laradocs\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Laradocs\\LaradocsServiceProvider"
            ],
            "aliases": {
                "Laradocs": "Laradocs\\Facades\\Laradocs"
            }
        }
    },
    "scripts": {
        "lint": "find src config tests -name '*.php' -print0 | xargs -0 -n1 php -l",
        "test:lint": "@lint",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=1G",
        "test:unit": "vendor/bin/pest",
        "test:coverage": "vendor/bin/pest --coverage --min=100",
        "test": [
            "@test:lint",
            "@test:unit"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
