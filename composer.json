{
    "name": "petebishwhip/laradocs",
    "description": "Maintain beautiful, version-controlled documentation alongside your Laravel codebase. Markdown in, a polished docs site out.",
    "keywords": [
        "laravel",
        "documentation",
        "docs",
        "markdown",
        "commonmark"
    ],
    "homepage": "https://github.com/petebishwhip/laradocs",
    "license": "MIT",
    "authors": [
        {
            "name": "Pete Bishop",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.14 || ^12.0 || ^13.0",
        "illuminate/support": "^11.14 || ^12.0 || ^13.0",
        "league/commonmark": "^2.4",
        "ralphjsmit/laravel-seo": "^1.8",
        "spatie/yaml-front-matter": "^2.0"
    },
    "require-dev": {
        "larastan/larastan": "^2.9 || ^3.0",
        "laravel/pint": "^1.18",
        "laravel/scout": "^10.0",
        "meilisearch/meilisearch-php": "^1.0",
        "nyholm/psr7": "^1.5",
        "orchestra/testbench": "^9.0 || ^10.0 || ^11.0",
        "orchestra/workbench": "^9.0 || ^10.0 || ^11.0",
        "pestphp/pest": "^3.0 || ^4.0",
        "pestphp/pest-plugin-laravel": "^3.0 || ^4.0",
        "phpstan/phpstan": "^1.11 || ^2.0",
        "rector/rector": "^1.2 || ^2.0"
    },
    "suggest": {
        "laravel/scout": "Power full-text docs search with Meilisearch, Typesense or Algolia (falls back to a built-in JSON index).",
        "nyholm/psr7": "When using Meilisearch via Scout, install a PSR-17 factory (nyholm/psr7, guzzlehttp/psr7 ^2, or symfony/http-client) so the Meilisearch SDK can build HTTP requests."
    },
    "autoload": {
        "psr-4": {
            "Laradocs\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Laradocs\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Laradocs\\LaradocsServiceProvider"
            ],
            "aliases": {
                "Laradocs": "Laradocs\\Facades\\Laradocs"
            }
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ],
        "lint": "vendor/bin/pint",
        "test:lint": "vendor/bin/pint --test",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=1G",
        "refactor": "vendor/bin/rector",
        "test:refactor": "vendor/bin/rector --dry-run",
        "test:unit": "vendor/bin/pest",
        "test:coverage": "vendor/bin/pest --coverage --min=100",
        "test": [
            "@test:lint",
            "@analyse",
            "@test:unit"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
